# Copy this file to data_pipeline/.env and fill in your values.

GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=your_gemini_api_key_here

# Optional overrides for run_llm_categorization
DATA_PIPELINE_LLM_PROVIDER=google
DATA_PIPELINE_LLM_MODEL=gemini-2.5-flash
DATA_PIPELINE_LLM_TEMPERATURE=0.1
DATA_PIPELINE_LLM_MAX_TOKENS=4000
DATA_PIPELINE_LLM_TIMEOUT_SECONDS=120
DATA_PIPELINE_LLM_RETRY_COUNT=2
DATA_PIPELINE_LLM_RETRY_BACKOFF_SECONDS=2.0
# DATA_PIPELINE_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Optional overrides for the live Kalshi provider.
# The currently implemented discovery and history endpoints are public and do not
# require an API key.
# DATA_PIPELINE_KALSHI_LIVE_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
# DATA_PIPELINE_KALSHI_LIVE_TIMEOUT_SECONDS=30
# DATA_PIPELINE_KALSHI_LIVE_RETRY_COUNT=3
# DATA_PIPELINE_KALSHI_LIVE_RETRY_BACKOFF_SECONDS=1.5
# DATA_PIPELINE_KALSHI_LIVE_MARKET_PAGE_LIMIT=1000
# DATA_PIPELINE_KALSHI_LIVE_DISCOVERY_LOOKBACK_DAYS=120
